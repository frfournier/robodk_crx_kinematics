# Published image to run, or the local tag produced by compose.build.yaml.
ROBODK_IMAGE=robodk-crx-kinematics:local

# Bind the API to loopback by default. Use 0.0.0.0 only when remote access is intended.
ROBODK_BIND_ADDRESS=127.0.0.1
ROBODK_PORT=20501
ROBODK_DATA_DIR=./data

# Local build metadata.
CRX_KINEMATICS_VERSION=0.3.1

# Required only while building. Setting it confirms that you reviewed the RoboDK EULA.
ROBODK_ACCEPT_EULA=yes
